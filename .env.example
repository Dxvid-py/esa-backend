# Base de datos PostgreSQL (Railway te da esta URL automáticamente)
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_db

# JWT Secret — pon cualquier cadena larga y aleatoria
JWT_SECRET=esa_website_super_secret_key_2026_cambiame

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# Entorno
NODE_ENV=production

# Correos del equipo admin (separados por coma)
ADMIN_EMAILS=esawebsite.contacto@gmail.com,emanuel@gmail.com,santiago@gmail.com,andres@gmail.com
